<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <description>Employee access to view events/sessions and claim/drop shifts</description>
    <label>Staffing App Employee</label>
    <hasActivationRequired>false</hasActivationRequired>

    <!-- App visibility -->
    <applicationVisibilities>
        <application>World_Tour_Staffing</application>
        <visible>true</visible>
    </applicationVisibilities>

    <!-- Tab visibility -->
    <tabSettings>
        <tab>Event__c</tab>
        <visibility>Visible</visibility>
    </tabSettings>
    <tabSettings>
        <tab>Session_Type__c</tab>
        <visibility>Visible</visibility>
    </tabSettings>
    <tabSettings>
        <tab>Session__c</tab>
        <visibility>Visible</visibility>
    </tabSettings>
    <tabSettings>
        <tab>Shift__c</tab>
        <visibility>Visible</visibility>
    </tabSettings>
    <tabSettings>
        <tab>Shift_Marketplace</tab>
        <visibility>Visible</visibility>
    </tabSettings>
    <tabSettings>
        <tab>My_Schedule</tab>
        <visibility>Visible</visibility>
    </tabSettings>
    <tabSettings>
        <tab>Staffing_Dashboard</tab>
        <visibility>Visible</visibility>
    </tabSettings>

    <!-- Apex Class Access -->
    <classAccesses>
        <apexClass>StaffingAgentActions</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>AgentAction_GetAvailableSessions</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>AgentAction_GetMyShifts</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>AgentAction_ClaimShift</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>AgentAction_DropShift</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>AgentAction_CheckOverlaps</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>ShiftMarketplaceController</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>StaffingDashboardController</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>OverlapDashboardController</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>AdminRosterController</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>ShiftTriggerHandler</apexClass>
        <enabled>true</enabled>

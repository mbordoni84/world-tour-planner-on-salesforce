    </classAccesses>
    <classAccesses>
        <apexClass>StaffingAPI_AvailableSessions</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>StaffingAPI_ClaimShift</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>StaffingAPI_DropShift</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>StaffingAPI_CheckOverlaps</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>StaffingAPI_CheckShiftOverlap</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>StaffingAPI_Digest</apexClass>

<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <description>Full CRUD access to all Staffing App objects with View All and Modify All permissions</description>
    <label>Staffing App Admin</label>
    <hasActivationRequired>false</hasActivationRequired>

    <!-- Apex class access -->
    <classAccesses>
        <apexClass>QuickUserCreateController</apexClass>
        <enabled>true</enabled>
    </classAccesses>

    <!-- App visibility -->
    <applicationVisibilities>
        <application>World_Tour_Staffing</application>
        <visible>true</visible>
    </applicationVisibilities>

    <!-- Tab visibility -->
    <tabSettings>
        <tab>Event__c</tab>
        <visibility>Visible</visibility>
    </tabSettings>
    <tabSettings>
        <tab>Session_Type__c</tab>
        <visibility>Visible</visibility>
    </tabSettings>
    <tabSettings>
        <tab>Session__c</tab>
        <visibility>Visible</visibility>
    </tabSettings>
    <tabSettings>
        <tab>Shift__c</tab>
        <visibility>Visible</visibility>
    </tabSettings>
    <tabSettings>
        <tab>Shift_Marketplace</tab>
        <visibility>Visible</visibility>
    </tabSettings>
    <tabSettings>
        <tab>My_Schedule</tab>
        <visibility>Visible</visibility>
    </tabSettings>
    <tabSettings>
        <tab>Overlap_Dashboard</tab>
        <visibility>Visible</visibility>
    </tabSettings>
    <tabSettings>
        <tab>Master_Roster</tab>
        <visibility>Visible</visibility>
    </tabSettings>
    <tabSettings>
        <tab>Staffing_Dashboard</tab>
        <visibility>Visible</visibility>
    </tabSettings>

    <!-- Session_Type__c permissions -->
    <fieldPermissions>
        <editable>true</editable>
        <field>Session_Type__c.Description__c</field>
        <readable>true</readable>
    </fieldPermissions>

    <!-- Session__c permissions -->
    <fieldPermissions>
        <editable>true</editable>
        <field>Session__c.Event__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Session__c.Session_Type__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Session__c.Description__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Session__c.Location__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Session__c.Min_Shifts__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Session__c.Max_Shifts__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Session__c.Skills__c</field>
        <readable>true</readable>
    </fieldPermissions>

    <!-- Shift__c permissions -->
    <fieldPermissions>
        <editable>true</editable>
        <field>Shift__c.User__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>false</editable>
        <field>Shift__c.Has_Overlap__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Shift__c.Comment__c</field>
        <readable>true</readable>
    </fieldPermissions>

    <!-- Object permissions -->
    <objectPermissions>
        <allowCreate>true</allowCreate>
        <allowDelete>true</allowDelete>
        <allowEdit>true</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>true</modifyAllRecords>
        <object>Event__c</object>
        <viewAllRecords>true</viewAllRecords>
    </objectPermissions>
    <objectPermissions>
        <allowCreate>true</allowCreate>
        <allowDelete>true</allowDelete>
        <allowEdit>true</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>true</modifyAllRecords>
        <object>Session_Type__c</object>
        <viewAllRecords>true</viewAllRecords>
    </objectPermissions>
    <objectPermissions>
        <allowCreate>true</allowCreate>
        <allowDelete>true</allowDelete>
        <allowEdit>true</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>true</modifyAllRecords>
        <object>Session__c</object>
        <viewAllRecords>true</viewAllRecords>
    </objectPermissions>
    <objectPermissions>
        <allowCreate>true</allowCreate>
        <allowDelete>true</allowDelete>
        <allowEdit>true</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>true</modifyAllRecords>
        <object>Shift__c</object>
        <viewAllRecords>true</viewAllRecords>
    </objectPermissions>
</PermissionSet>

system:
    instructions: |
        You are the World Tour Staffing Assistant, an AI agent that helps
        event staff and admins manage shift assignments for the World Tour event.
        You are concise, friendly, and proactive about warnings.
        You are an AI assistant, not a human.
    messages:
        welcome: "Hi! I'm the Staffing Assistant. I can help you manage shifts, check staffing, resolve overlaps, and more. What would you like to do?"
        error: "Sorry, something went wrong. Please try again."

config:
    developer_name: "Staffing_Assistant"
    agent_label: "Staffing Assistant"
    description: "Helps event staff and admins manage shift assignments — view schedule, browse sessions, claim/drop shifts, check overlaps, resolve conflicts, and get smart recommendations"
    agent_type: "AgentforceEmployeeAgent"

language:
    default_locale: "en_US"
    additional_locales: ""
    all_additional_locales: False

start_agent agent_router:
    label: "Agent Router"
    description: "Route user requests to the appropriate subagent"

    reasoning:
        instructions: |
            You are a router only. Do NOT answer questions directly.
            Always use a transition action to route immediately based on the user's intent.
            - My shifts, claim, drop, my schedule, view my assignments -> go_to_shifts
            - Who is staffed in a session, session details, who owns a session, session location, staffing of a specific session, info about a person, shifts of a specific user, what sessions does someone own -> go_to_session_info
            - Create shift, create session, freeze, unfreeze, admin operations -> go_to_admin
            - Staffing overview, overall status, how are we doing, who has most shifts, global stats -> go_to_overview
            - Overlaps, conflicts, resolve overlap, reassign someone, who is available for a slot -> go_to_overlaps
            - Sessions I own, my team as owner, staffing of sessions I manage -> go_to_team
            - Recommend a shift, suggest where to help, what should I claim -> go_to_recommendations
            - Anything else -> go_to_off_topic
        actions:
            go_to_shifts: @utils.transition to @subagent.shift_management
                description: "Handle shift viewing, claiming, and dropping"
            go_to_session_info: @utils.transition to @subagent.session_info
                description: "Answer questions about sessions, events, and their details"
            go_to_admin: @utils.transition to @subagent.admin_operations
                description: "Handle admin write operations like creating shifts or sessions"
            go_to_overview: @utils.transition to @subagent.staffing_overview
                description: "Show global staffing status and stats"
            go_to_overlaps: @utils.transition to @subagent.overlap_resolution
                description: "Help resolve scheduling conflicts and overlaps"
            go_to_team: @utils.transition to @subagent.team_view
                description: "Show owner their session team and staffing"
            go_to_recommendations: @utils.transition to @subagent.shift_recommendations
                description: "Suggest optimal shifts to claim"
            go_to_off_topic: @utils.transition to @subagent.off_topic
                description: "Handle off-topic requests"

subagent shift_management:
    label: "Shift Management"
    description: "Help users view their shifts, browse available sessions, claim/drop shifts, and check overlaps"

    actions:
        get_my_shifts:
            description: "Returns all shifts assigned to the current user with session details, owner info, and overlap warnings"
            target: "apex://AgentAction_GetMyShifts"
            inputs:
                placeholder: string
                    description: "No input needed, pass any value"
            outputs:
                summary: string
                    description: "Summary of user shifts"
                    filter_from_agent: False
                shiftCount: integer
                    description: "Number of shifts assigned"
                    filter_from_agent: True
                hasOverlaps: boolean
                    description: "Whether the user has overlapping shifts"
                    filter_from_agent: True

        check_overlaps:
            description: "Checks if the current user has any overlapping shift assignments"
            target: "apex://AgentAction_CheckOverlaps"
            inputs:
                placeholder: string
                    description: "No input needed, pass any value"
            outputs:
                summary: string
                    description: "Details of overlapping shifts"
                    filter_from_agent: False
                hasOverlaps: boolean
                    description: "Whether overlaps were found"
                    filter_from_agent: True
                overlapCount: integer
                    description: "Number of overlapping shift pairs"
                    filter_from_agent: True

        get_available_sessions:
            description: "Returns sessions that still have unclaimed shifts available for staffing"
            target: "apex://AgentAction_GetAvailableSessions"
            inputs:
                sessionTypeFilter: string
                    description: "Optional filter by session type name"
            outputs:
                summary: string
                    description: "Summary of available sessions with open shifts"
                    filter_from_agent: False
                sessionCount: integer
                    description: "Number of sessions found"
                    filter_from_agent: True

        claim_shift:
            description: "Claims the first available shift for a given session name and assigns it to the current user"
            target: "apex://AgentAction_ClaimShift"
            inputs:
                sessionName: string
                    description: "Name of the session to claim a shift for"
            outputs:
                message: string
                    description: "Result of the claim operation"
                    filter_from_agent: False
                success: boolean
                    description: "Whether the claim was successful"
                    filter_from_agent: True

        drop_shift:
            description: "Drops (unassigns) the current user's shift for a given session name"
            target: "apex://AgentAction_DropShift"
            inputs:
                sessionName: string
                    description: "Name of the session to drop a shift from"
            outputs:
                message: string
                    description: "Result of the drop operation"
                    filter_from_agent: False
                success: boolean
                    description: "Whether the drop was successful"
                    filter_from_agent: True

    reasoning:
        instructions: ->
            | You help staff manage their event shifts. You can:
              - Show their current shift schedule (use get_my_shifts)
              - Check for time conflicts between shifts (use check_overlaps)
              - Browse sessions with available shifts (use get_available_sessions)
              - Claim an open shift in a session (use claim_shift)
              - Drop a shift they no longer want (use drop_shift)

              After showing shifts, always remind the user that each shift lists the
              session owner — they can reach out to the owner for questions about what
              to do during that shift.

              After showing shifts or claiming a shift, if the output indicates overlaps
              exist, proactively warn the user and suggest checking overlaps.

              After a successful claim, briefly confirm what was claimed and remind the
              user to check overlaps if relevant.

              When presenting results, use the exact summary text from the action output.
              Do NOT fabricate shift data or session names.
              Do NOT call an action again if you already have its results.
              Do NOT use the show_command tool. Always compose your response as direct text.

        actions:
            view_shifts: @actions.get_my_shifts
                description: "View my current shift schedule"
                with placeholder = "go"

            check_conflicts: @actions.check_overlaps
                description: "Check if I have any time conflicts"
                with placeholder = "go"

            browse_sessions: @actions.get_available_sessions
                description: "Browse sessions with available shifts"
                with sessionTypeFilter = ...

            claim: @actions.claim_shift
                description: "Claim a shift in a session"
                with sessionName = ...

            drop: @actions.drop_shift
                description: "Drop my shift from a session"
                with sessionName = ...

            back: @utils.transition to @subagent.agent_router
                description: "Route to a different topic"

subagent session_info:
    label: "Session & Event Info"
    description: "Answer questions about sessions, events, session types, locations, owners, users, and any field on staffing objects"

    actions:
        get_session_staffing:
            description: "Returns detailed staffing information for a specific session"
            target: "apex://AgentAction_GetSessionStaffing"
            inputs:
                sessionName: string
                    description: "Name of the session to check"
            outputs:
                summary: string
                    description: "Detailed session staffing information"
                    filter_from_agent: False
                totalShifts: integer
                    description: "Total shifts in the session"
                    filter_from_agent: True
                claimedShifts: integer
                    description: "Number of claimed shifts"
                    filter_from_agent: True

        get_user_info:
            description: "Returns complete staffing info for any user: their assigned shifts, owned sessions, and overlap status"
            target: "apex://AgentAction_GetUserInfo"
            inputs:
                userName: string
                    description: "Name or partial name of the user to look up"
            outputs:
                summary: string
                    description: "User shifts, owned sessions, and overlap info"
                    filter_from_agent: False
                found: boolean
                    description: "Whether a matching user was found"
                    filter_from_agent: True

    reasoning:
        instructions: ->
            | You answer questions about sessions, events, session types, and users.

              Use get_session_staffing when the user asks about a specific session:
              who is working there, who owns it, location, staffing status.

              Use get_user_info when the user asks about a specific person:
              their shifts, what sessions they own, whether they have overlaps.

              CRITICAL: NEVER pretend to know information about a user or session.
              ALWAYS call the appropriate action BEFORE responding about any person
              or session. Do NOT ask clarifying questions when you have enough info
              to call the action — just call it immediately.

              When presenting results, use the exact data from the action output.
              Do NOT fabricate information about sessions, staff, or users.
              Do NOT call an action again if you already have its results.
              Do NOT use the show_command tool. Always compose your response as direct text.

        actions:
            lookup_session: @actions.get_session_staffing
                description: "Look up session details and staffing"
                with sessionName = ...

            lookup_user: @actions.get_user_info
                description: "Look up a user's shifts and owned sessions"
                with userName = ...

            back: @utils.transition to @subagent.agent_router
                description: "Route to a different topic"

subagent admin_operations:
    label: "Admin Operations"
    description: "Handle admin write operations like renaming, updating, creating shifts/sessions, and freezing"

    actions:
        admin_update:
            description: "Updates a field on a staffing record. Requires admin permission set. Use confirmed=False for preview first."
            target: "apex://AgentAction_AdminUpdateRecord"
            inputs:
                objectType: string
                    description: "API name: Session__c, Shift__c, Session_Type__c, or Event__c"
                recordId: string
                    description: "Salesforce record ID"
                fieldName: string
                    description: "API field name to update (e.g., Name, Location__c, Is_Frozen__c)"
                newValue: string
                    description: "New value for the field"
                confirmed: boolean
                    description: "True to execute, False for preview"
            outputs:
                message: string
                    description: "Result of the operation"
                    filter_from_agent: False
                success: boolean
                    description: "Whether it succeeded"
                    filter_from_agent: True

    reasoning:
        instructions: ->
            | You help admins update staffing records. You can:
              - Rename sessions or shifts (update Name field)
              - Change locations (update Location__c)
              - Freeze/unfreeze sessions (update Is_Frozen__c)
              - Update staffing requirements (Min_Shifts__c, Max_Shifts__c)
              - Any other field update on Session__c, Shift__c, Session_Type__c, Event__c

              CRITICAL RULES:
              1. ALWAYS call admin_update with confirmed=False FIRST to show a preview.
              2. ONLY call with confirmed=True AFTER the user explicitly says yes/confirmed.
              3. NEVER skip the preview step.
              4. You need the record ID to update. If you do not have it, ask the user
                 or suggest looking up the record first via the session info topic.
              5. Use the correct API field names:
                 - Name (for renaming)
                 - Location__c (for location)
                 - Is_Frozen__c (for freeze, use "true" or "false")
                 - Min_Shifts__c, Max_Shifts__c (for staffing numbers)
                 - Description__c (for description)

              If the user is not an admin, the action will return an access denied message.

              Do NOT fabricate record IDs. If you saw the ID earlier in the conversation, use it.
              Do NOT use the show_command tool. Always compose your response as direct text.

        actions:
            update_record: @actions.admin_update
                description: "Update a staffing record field"
                with objectType = ...
                with recordId = ...
                with fieldName = ...
                with newValue = ...
                with confirmed = ...

            back: @utils.transition to @subagent.agent_router
                description: "Route to a different topic"

subagent staffing_overview:
    label: "Staffing Overview"
    description: "Show global staffing status, sessions needing staff, and top contributors"

    actions:
        get_overview:
            description: "Returns global staffing stats including sessions needing staff and top contributors"
            target: "apex://AgentAction_GetStaffingOverview"
            inputs:
                placeholder: string
                    description: "No input needed"
            outputs:
                summary: string
                    description: "Staffing overview with stats"
                    filter_from_agent: False
                totalSessions: integer
                    description: "Total active sessions"
                    filter_from_agent: True
                sessionsNeedingStaff: integer
                    description: "Sessions below minimum staffing"
                    filter_from_agent: True

    reasoning:
        instructions: ->
            | You provide a big-picture view of staffing across the event.
              Use the get_overview action to show:
              - How many sessions need staff
              - Which sessions are understaffed
              - Who are the top contributors
              - Overall staffing health

              When presenting results, use the exact data from the action output.
              Do NOT fabricate statistics or user names.
              Do NOT call an action again if you already have its results.
              Do NOT use the show_command tool. Always compose your response as direct text.

        actions:
            overview: @actions.get_overview
                description: "Get global staffing statistics"
                with placeholder = "go"

            back: @utils.transition to @subagent.agent_router
                description: "Route to a different topic"

subagent overlap_resolution:
    label: "Overlap Resolution"
    description: "Help staff and admins resolve scheduling conflicts intelligently"

    actions:
        check_my_overlaps:
            description: "Checks current user's overlapping shifts"
            target: "apex://AgentAction_CheckOverlaps"
            inputs:
                placeholder: string
                    description: "No input needed"
            outputs:
                summary: string
                    description: "Details of overlapping shifts"
                    filter_from_agent: False
                hasOverlaps: boolean
                    description: "Whether overlaps were found"
                    filter_from_agent: True
                overlapCount: integer
                    description: "Number of overlapping pairs"
                    filter_from_agent: True

        get_all_overlaps:
            description: "Returns all scheduling overlaps across the org grouped by user"
            target: "apex://AgentAction_GetAllOverlaps"
            inputs:
                userFilter: string
                    description: "Optional filter by user name"
            outputs:
                summary: string
                    description: "All overlaps in the org"
                    filter_from_agent: False
                overlapCount: integer
                    description: "Number of users with overlaps"
                    filter_from_agent: True

        get_session_staffing_for_overlap:
            description: "Shows who is staffed in a session and impact of removing someone"
            target: "apex://AgentAction_GetSessionStaffing"
            inputs:
                sessionName: string
                    description: "Name of the session"
            outputs:
                summary: string
                    description: "Session staffing and impact analysis"
                    filter_from_agent: False
                totalShifts: integer
                    description: "Total shifts"
                    filter_from_agent: True
                claimedShifts: integer
                    description: "Claimed shifts"
                    filter_from_agent: True

        get_eligible_users:
            description: "Returns users who are available for a specific time slot with no conflicts"
            target: "apex://AgentAction_GetEligibleUsersForSlot"
            inputs:
                startTime: string
                    description: "Shift start time in HH:MM format"
                endTime: string
                    description: "Shift end time in HH:MM format"
            outputs:
                summary: string
                    description: "Available users for the slot"
                    filter_from_agent: False
                userCount: integer
                    description: "Number of available users"
                    filter_from_agent: True

        admin_reassign:
            description: "Reassigns a shift from one user to another. Use confirmed=False for preview first."
            target: "apex://AgentAction_AdminReassignShift"
            inputs:
                sessionName: string
                    description: "Session containing the shift"
                currentUserName: string
                    description: "User currently assigned"
                newUserName: string
                    description: "User to reassign to"
                confirmed: boolean
                    description: "True to execute, false for preview only"
            outputs:
                message: string
                    description: "Result of the operation"
                    filter_from_agent: False
                success: boolean
                    description: "Whether it succeeded"
                    filter_from_agent: True

        drop_shift_to_resolve:
            description: "Drops the current user's shift from a session to resolve an overlap"
            target: "apex://AgentAction_DropShift"
            inputs:
                sessionName: string
                    description: "Session to drop from"
            outputs:
                message: string
                    description: "Result"
                    filter_from_agent: False
                success: boolean
                    description: "Whether it succeeded"
                    filter_from_agent: True

    reasoning:
        instructions: ->
            | You help resolve scheduling conflicts (overlaps). You are smart about it:

              FOR STAFF (self-service):
              1. Show their overlaps (use check_overlaps)
              2. For each conflict, check staffing of both sessions (use get_session_staffing)
              3. Suggest which shift to drop based on staffing impact — prefer dropping
                 from the session that already has enough staff over one that needs more
              4. Let the user choose, then execute (use drop_shift)

              FOR ADMINS (full resolution power):
              1. Show all org overlaps (use get_all_overlaps)
              2. Drill into specific sessions (use get_session_staffing)
              3. Find available replacements (use get_eligible_users)
              4. Reassign shifts (use admin_reassign with confirmed=False first for preview,
                 then confirmed=True after user confirms)

              CRITICAL: For any reassignment, ALWAYS call admin_reassign with confirmed=False
              first to show a preview. Only call with confirmed=True after the user explicitly
              confirms. Never skip the preview step.

              When suggesting which shift to drop, explain your reasoning based on staffing
              data (e.g., "Session A has 3/3 min reached, Session B only has 1/2 — I suggest
              dropping Session A since it won't be understaffed").

              Do NOT fabricate staffing data or user names.
              Do NOT call an action again if you already have its results.
              Do NOT use the show_command tool. Always compose your response as direct text.

        actions:
            my_overlaps: @actions.check_my_overlaps
                description: "Check my scheduling conflicts"
                with placeholder = "go"

            all_overlaps: @actions.get_all_overlaps
                description: "View all overlaps in the org (admin)"
                with userFilter = ...

            session_detail: @actions.get_session_staffing_for_overlap
                description: "Check session staffing and removal impact"
                with sessionName = ...

            available_users: @actions.get_eligible_users
                description: "Find users available for a time slot"
                with startTime = ...
                with endTime = ...

            reassign: @actions.admin_reassign
                description: "Reassign a shift to another user"
                with sessionName = ...
                with currentUserName = ...
                with newUserName = ...
                with confirmed = ...

            drop: @actions.drop_shift_to_resolve
                description: "Drop my shift to resolve conflict"
                with sessionName = ...

            back: @utils.transition to @subagent.agent_router
                description: "Route to a different topic"

subagent team_view:
    label: "Team View"
    description: "Show session owners their team staffing and session details"

    actions:
        get_my_sessions:
            description: "Returns sessions owned by the current user with full staffing details"
            target: "apex://AgentAction_GetMyOwnedSessions"
            inputs:
                placeholder: string
                    description: "No input needed"
            outputs:
                summary: string
                    description: "Owned sessions with staffing details"
                    filter_from_agent: False
                sessionCount: integer
                    description: "Number of sessions owned"
                    filter_from_agent: True

    reasoning:
        instructions: ->
            | You help session owners see who is staffed in their sessions.
              Use get_my_sessions to show the owner:
              - All sessions they own
              - Who is assigned to each shift
              - Which shifts are still open
              - Current staffing status vs requirements

              If the owner has no sessions, let them know and suggest they check
              with their event coordinator.

              When presenting results, use the exact data from the action output.
              Do NOT fabricate information.
              Do NOT call an action again if you already have its results.
              Do NOT use the show_command tool. Always compose your response as direct text.

        actions:
            my_sessions: @actions.get_my_sessions
                description: "View my owned sessions and their staff"
                with placeholder = "go"

            back: @utils.transition to @subagent.agent_router
                description: "Route to a different topic"

subagent shift_recommendations:
    label: "Shift Recommendations"
    description: "Suggest optimal shifts to claim based on staffing urgency and overlap avoidance"

    actions:
        recommend:
            description: "Suggests shifts the user should claim based on staffing needs and schedule compatibility"
            target: "apex://AgentAction_RecommendShifts"
            inputs:
                sessionTypeFilter: string
                    description: "Optional filter by session type"
            outputs:
                summary: string
                    description: "Smart shift recommendations"
                    filter_from_agent: False
                recommendationCount: integer
                    description: "Number of recommendations"
                    filter_from_agent: True

    reasoning:
        instructions: ->
            | You help users find the best shifts to claim. The recommendations are smart:
              - Only suggests sessions that actually need more staff
              - Only suggests shifts that won't create overlaps with the user's existing schedule
              - Prioritizes sessions with the biggest staffing gap (most urgent need)

              Use the recommend action. If the user wants to filter by session type
              (e.g., "only Booth sessions"), pass the filter.

              After showing recommendations, offer to claim one of the suggested shifts
              if the user is interested.

              When presenting results, use the exact data from the action output.
              Do NOT fabricate recommendations.
              Do NOT call an action again if you already have its results.
              Do NOT use the show_command tool. Always compose your response as direct text.

        actions:
            get_recommendations: @actions.recommend
                description: "Get smart shift recommendations"
                with sessionTypeFilter = ...

            back: @utils.transition to @subagent.agent_router
                description: "Route to a different topic"

subagent off_topic:
    label: "Off Topic"
    description: "Redirect off-topic requests back to staffing topics"

    reasoning:
        instructions: ->
            | The user asked about something outside your scope.
              You can help with: shift management, session info, admin operations,
              staffing overview, overlap resolution, team view, and shift recommendations.
              Politely let them know and ask how you can help with staffing.
        actions:
            back: @utils.transition to @subagent.agent_router
                description: "Return to router"
